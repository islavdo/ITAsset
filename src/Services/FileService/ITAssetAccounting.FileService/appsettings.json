{
  "ConnectionStrings": {
    "FileDb": "Data Source=App_Data/files.db",
    "Redis": ""
  },
  "Jwt": {
    "Issuer": "ITAssetAccounting.IdentityService",
    "Audience": "ITAssetAccounting.Clients",
    "SigningKey": "DEV_ONLY_CHANGE_TO_64_SYMBOLS_MINIMUM_SECRET_FOR_JWT_SIGNING"
  },
  "FileStorage": {
    "RootPath": "storage",
    "MaxBytes": 10485760,
    "AllowedContentTypes": ["image/jpeg", "image/png", "application/pdf", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"]
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning", "Microsoft.AspNetCore": "Warning" } }
  },
  "AllowedHosts": "*"
}
