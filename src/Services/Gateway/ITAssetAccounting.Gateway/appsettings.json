{
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning", "Microsoft.AspNetCore": "Warning" } }
  },
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": { "Path": "/identity/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/{**catch-all}" } ]
      },
      "equipment": {
        "ClusterId": "equipment",
        "Match": { "Path": "/equipment/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/{**catch-all}" } ]
      },
      "maintenance": {
        "ClusterId": "maintenance",
        "Match": { "Path": "/maintenance/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/{**catch-all}" } ]
      },
      "files": {
        "ClusterId": "files",
        "Match": { "Path": "/files/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/files/{**catch-all}" } ]
      },
      "reports": {
        "ClusterId": "reports",
        "Match": { "Path": "/reports/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/reports/{**catch-all}" } ]
      },
      "equipmentHub": {
        "ClusterId": "equipment",
        "Match": { "Path": "/hubs/equipment/{**catch-all}" }
      },
      "maintenanceHub": {
        "ClusterId": "maintenance",
        "Match": { "Path": "/hubs/maintenance/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": { "Destinations": { "d1": { "Address": "http://localhost:5101/" } } },
      "equipment": { "Destinations": { "d1": { "Address": "http://localhost:5102/" } } },
      "maintenance": { "Destinations": { "d1": { "Address": "http://localhost:5103/" } } },
      "files": { "Destinations": { "d1": { "Address": "http://localhost:5104/" } } },
      "reports": { "Destinations": { "d1": { "Address": "http://localhost:5105/" } } }
    }
  },
  "AllowedHosts": "*"
}
